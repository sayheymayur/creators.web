VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Payments
# - Backend decides active gateway via GET /payments/gateway (auth). End users do NOT choose Razorpay vs Stripe.
# - The VITE_PAYMENTS_* vars below are ONLY a fallback if the gateway API is unavailable (local dev/offline).
#
# Local "mock backend" (no network): simulate GET /payments/gateway response
# - true: creatorsApi.payments.getGateway() returns the values below instead of calling the API
VITE_PAYMENTS_GATEWAY_MOCK=
# razorpay | stripe
VITE_PAYMENTS_GATEWAY_PROVIDER=
# true: simulated gateway response forces mock checkout (no real SDK)
VITE_PAYMENTS_GATEWAY_USE_MOCK=
#
# Fallback only (used when gateway API fails and VITE_PAYMENTS_GATEWAY_MOCK is not enabled)
# razorpay | stripe
VITE_PAYMENTS_PROVIDER=razorpay
# true: simulated checkout (no real SDK)
VITE_PAYMENTS_MOCK=true
# Optional delay (ms) for mock checkout
# VITE_PAYMENTS_MOCK_DELAY_MS=600
#
# Public client keys (required only when mock checkout is false and that provider is active)
# Stripe publishable key (pk_test_...) — client-only; real charges still require backend PaymentIntent/Checkout.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Firebase Web SDK config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional backend endpoint for secure token exchange
# If omitted, frontend falls back to a local profile mapping.
VITE_AUTH_EXCHANGE_URL=

# App mode
# - true: use local mock posts + demo accounts for fast UI work
# - false/empty: use real API + WebSocket
VITE_POSTS_MOCK=

# Creators API endpoints (optional overrides)
VITE_CREATORS_API_URL=
VITE_CREATORS_WS_URL=
VITE_CREATORS_WS_PATH=
VITE_CREATORS_WS_TOKEN_PARAM=

# Legacy WebSocket env aliases (still supported by WsClient)
VITE_WS_URL=
VITE_WS_PATH=
